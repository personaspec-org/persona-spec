{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://personaspec.org/schema/v1/persona.schema.json",
  "title": "Persona Interchange Format (PIF) v1.0",
  "description": "JSON Schema for validating .persona files conforming to the Persona Interchange Format specification v1.0",
  "type": "object",
  "required": ["version", "identity"],
  "additionalProperties": true,
  "properties": {

    "version": {
      "type": "string",
      "description": "PIF spec version this file conforms to",
      "enum": ["1.0"]
    },

    "meta": {
      "type": "object",
      "description": "File metadata",
      "additionalProperties": true,
      "properties": {
        "spec":           { "type": "string", "format": "uri" },
        "min_compatible": { "type": "string" },
        "created":        { "type": "string", "format": "date" },
        "updated":        { "type": "string", "format": "date" },
        "username":       { "type": "string", "minLength": 3, "maxLength": 30, "pattern": "^[a-z0-9-]+$" },
        "url":            { "type": "string", "format": "uri" },
        "visibility":     { "type": "string", "enum": ["public", "private"] },
        "api_enabled":    { "type": "boolean" }
      }
    },

    "identity": {
      "type": "object",
      "description": "Core identity fields",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name":     { "type": "string", "minLength": 1, "maxLength": 100 },
        "tagline":  { "type": "string", "maxLength": 200 },
        "location": { "type": "string", "maxLength": 100 }
      }
    },

    "voice": {
      "type": "object",
      "description": "Communication style and voice examples",
      "additionalProperties": true,
      "properties": {
        "tone": {
          "type": "string",
          "enum": ["Casual", "Professional", "Formal", "Playful", "Direct", "Warm"]
        },
        "style": {
          "type": "string",
          "enum": ["Concise", "Detailed", "Storyteller", "Analytical", "Conversational"]
        },
        "personality_narrative": {
          "type": "string",
          "maxLength": 1000,
          "description": "AI-synthesized personality description. Private by default."
        },
        "examples": {
          "type": "array",
          "description": "Voice examples as prompt/response pairs",
          "items": {
            "type": "object",
            "required": ["prompt", "response"],
            "additionalProperties": false,
            "properties": {
              "prompt":   { "type": "string", "minLength": 1 },
              "response": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },

    "rules": {
      "type": "object",
      "description": "Behavioral rules governing the persona",
      "additionalProperties": true,
      "properties": {
        "transparency": {
          "type": "string",
          "enum": ["always", "if_asked", "never"],
          "default": "if_asked",
          "description": "How the persona handles questions about being an AI"
        },
        "behaviors": {
          "type": "array",
          "description": "Standard behavior flags",
          "items": {
            "type": "string",
            "enum": ["no_opinions", "no_commitments", "deflect_personal", "stay_on_topic"]
          }
        },
        "custom": {
          "type": "array",
          "description": "Freeform rules as plain English strings",
          "items": { "type": "string" }
        },
        "blocked_topics": {
          "type": "array",
          "description": "Topics the persona will not discuss",
          "items": { "type": "string" }
        },
        "cta": {
          "type": "string",
          "description": "Call to action shown when someone expresses genuine interest in connecting"
        }
      }
    },

    "privacy": {
      "type": "object",
      "description": "Field-level privacy controls",
      "additionalProperties": true,
      "properties": {
        "personality_narrative": { "$ref": "#/definitions/privacyLevel" },
        "professional":          { "$ref": "#/definitions/privacyLevel" },
        "personal":              { "$ref": "#/definitions/privacyLevel" },
        "social":                { "$ref": "#/definitions/privacyLevel" },
        "commerce":              { "$ref": "#/definitions/privacyLevel" },
        "learning":              { "$ref": "#/definitions/privacyLevel" },
        "location":              { "$ref": "#/definitions/privacyLevel" },
        "employer":              { "$ref": "#/definitions/privacyLevel" }
      }
    },

    "sharing": {
      "type": "object",
      "description": "API access and consent controls",
      "additionalProperties": true,
      "properties": {
        "public_api": {
          "type": "boolean",
          "default": true,
          "description": "Whether the public API is enabled for this persona"
        },
        "allowed_scopes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowed_contexts": {
          "type": "array",
          "items": { "$ref": "#/definitions/contextValue" }
        },
        "blocked_contexts": {
          "type": "array",
          "items": { "$ref": "#/definitions/contextValue" }
        },
        "blocked_domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "require_attribution": {
          "type": "boolean",
          "default": true
        }
      }
    },

    "extensions": {
      "type": "object",
      "description": "Domain-specific context extensions",
      "additionalProperties": true,
      "properties": {

        "professional": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "role":              { "type": "string" },
            "company":          { "type": "string" },
            "industry":         { "type": "string" },
            "bio":              { "type": "string", "maxLength": 500 },
            "skills":           { "type": "array", "items": { "type": "string" } },
            "availability":     { "type": "string", "enum": ["open", "not_looking", "freelance", "closed"] },
            "preferred_contact":{ "type": "string" }
          }
        },

        "personal": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "interests":                 { "type": "array", "items": { "type": "string" } },
            "values":                    { "type": "array", "items": { "type": "string" } },
            "causes":                    { "type": "array", "items": { "type": "string" } },
            "personality_traits":        { "type": "array", "items": { "type": "string" } },
            "communication_preferences": { "type": "object", "additionalProperties": true }
          }
        },

        "social": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "handles": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "twitter":   { "type": "string" },
                "linkedin":  { "type": "string" },
                "github":    { "type": "string" },
                "instagram": { "type": "string" }
              }
            },
            "availability": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "open_to_meeting":        { "type": "boolean" },
                "open_to_collaboration":  { "type": "boolean" },
                "open_to_mentoring":      { "type": "boolean" },
                "open_to_being_mentored": { "type": "boolean" }
              }
            },
            "communication_style": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "preferred_medium": { "type": "string" },
                "response_time":    { "type": "string" },
                "preferred_format": { "type": "string" }
              }
            },
            "conversation_style": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "humor":  { "type": "string", "enum": ["dry", "sarcastic", "playful", "none", "dark", "absurdist"] },
                "depth":  { "type": "string", "enum": ["small talk", "balanced", "deep diver"] },
                "energy": { "type": "string", "enum": ["high energy", "measured", "low key"] }
              }
            },
            "topics": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "loves":     { "type": "array", "items": { "type": "string" } },
                "avoids":    { "type": "array", "items": { "type": "string" } },
                "expert_in": { "type": "array", "items": { "type": "string" } }
              }
            },
            "persona_to_persona": {
              "type": "object",
              "additionalProperties": true,
              "description": "Context used when two PIF personas interact directly",
              "properties": {
                "opener":       { "type": "string" },
                "ask_me_about": { "type": "array", "items": { "type": "string" } },
                "looking_for":  { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },

        "commerce": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "buying_preferences": { "type": "array", "items": { "type": "string" } },
            "brands":             { "type": "array", "items": { "type": "string" } },
            "budget_range":       { "type": "string" },
            "shopping_style":     { "type": "string" }
          }
        },

        "learning": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "current_topics":  { "type": "array", "items": { "type": "string" } },
            "learning_style":  { "type": "string" },
            "experience_level":{ "type": "object", "additionalProperties": true },
            "credentials":     { "type": "array", "items": { "type": "string" } }
          }
        }

      }
    },

    "modes": {
      "type": "object",
      "description": "Named configuration presets",
      "additionalProperties": {
        "$ref": "#/definitions/mode"
      },
      "properties": {
        "default":      { "$ref": "#/definitions/mode" },
        "professional": { "$ref": "#/definitions/mode" },
        "social":       { "$ref": "#/definitions/mode" },
        "minimal":      { "$ref": "#/definitions/mode" },
        "full":         { "$ref": "#/definitions/mode" }
      }
    }

  },

  "definitions": {

    "privacyLevel": {
      "type": "string",
      "enum": ["public", "authenticated", "private"]
    },

    "contextValue": {
      "type": "string",
      "enum": [
        "general",
        "professional",
        "job_application",
        "networking",
        "social",
        "dating",
        "customer_support",
        "education",
        "creative",
        "commerce"
      ]
    },

    "mode": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "active_extensions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "override_tone": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "enum": ["Casual", "Professional", "Formal", "Playful", "Direct", "Warm"] }
          ]
        },
        "override_style": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "enum": ["Concise", "Detailed", "Storyteller", "Analytical", "Conversational"] }
          ]
        },
        "privacy_level": { "$ref": "#/definitions/privacyLevel" },
        "custom_rules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }

  }
}
